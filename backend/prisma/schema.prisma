generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ここにテーブルを書く
model User {
  id        Int       @id @default(autoincrement())
  lastName  String
  firstName String
  gender    Int
  email     String    @unique
  age       Int
  isDeleted Boolean   @default(false)
  createdAt DateTime
  updatedAt DateTime
  posts     Diary[]
}

model Diary {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime
  updatedAt DateTime

  user   User? @relation(fields: [userId], references: [id])
  userId Int?
}
